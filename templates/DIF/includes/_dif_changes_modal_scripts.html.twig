<script>
    function initializeDifChangesModal() {
        const modal = document.getElementById('dif-changes-modal');
        const pageContent = document.getElementById('dif-page-content');
        if (!modal) {
            return;
        }

        const closeButton = document.getElementById('dif-changes-ok');
        const dontShowAgainButton = document.getElementById('dif-changes-ok-dont-show');

        const setPageDimmed = (isDimmed) => {
            if (pageContent) {
                pageContent.classList.toggle('dif-page-dimmed', isDimmed);
            }
        };

        const closeModal = () => {
            modal.classList.add('hidden');
            setPageDimmed(false);
        };

        setPageDimmed(!modal.classList.contains('hidden'));

        if (closeButton) {
            closeButton.addEventListener('click', closeModal);
        }

        if (dontShowAgainButton) {
            dontShowAgainButton.addEventListener('click', () => {
                const oneYearInSeconds = 60 * 60 * 24 * 365;
                document.cookie = `pelagos_dif_changes_acknowledged=1; path=/; max-age=${oneYearInSeconds}; samesite=lax`;
                closeModal();
            });
        }
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initializeDifChangesModal);
    } else {
        initializeDifChangesModal();
    }
</script>
