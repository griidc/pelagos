{% extends "base.html.twig" %}
{% block title %}System Statistics{% endblock %}

{% block head %}
    {{ parent() }}
    {# PWA Metadata #}
    <link rel="manifest" href="{{ asset('manifest.json') }}">
    <meta name="theme-color" content="#0066cc">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="default">
    <meta name="apple-mobile-web-app-title" content="GRIIDC Stats">
    <link rel="apple-touch-icon" href="{{ asset('build/images/griidc_fav-192x192.png') }}">
{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    {{ encore_entry_link_tags('stats') }}
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    
    {{ encore_entry_script_tags('stats') }}
    
    {# PWA Service Worker Registration #}
    <script>
        if ('serviceWorker' in navigator) {
            window.addEventListener('load', () => {
                navigator.serviceWorker.register('/stats-sw.js')
                    .then((registration) => {
                        console.log('Service Worker registered:', registration.scope);
                    })
                    .catch((error) => {
                        console.log('Service Worker registration failed:', error);
                    });
            });
        }
    </script>
{% endblock %}

{% block body %}
    <div class="bootstrap">
        <div class="container-fluid">
            <div id="stats">
            </div>
        </div> 
    </div>
{% endblock %}
