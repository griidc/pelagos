FROM rockylinux:9

LABEL description="Symfony Development Server — PHP 8.4"

# ── Repositories ──────────────────────────────────────────────────────────────
# EPEL: provides memcached and other extras
# Remi: provides PHP 8.4 (Rocky 9 AppStream only ships PHP 8.0)
# NodeSource: provides Node.js LTS (needed for yarn)
RUN dnf install -y --setopt=install_weak_deps=False epel-release \
    && dnf install -y --setopt=install_weak_deps=False \
        https://rpms.remirepo.net/enterprise/remi-release-9.rpm \
    && dnf module reset php -y \
    && dnf module enable php:remi-8.4 -y \
    && curl -fsSL https://rpm.nodesource.com/setup_lts.x | bash - \
    && dnf clean all -y

# ── System & PHP packages ─────────────────────────────────────────────────────
RUN dnf install -y --setopt=install_weak_deps=False \
        php-cli \
        php-common \
        php-intl \
        php-mbstring \
        php-xml \
        php-curl \
        php-zip \
        php-sodium \
        php-opcache \
        php-ctype \
        php-pdo \
        php-pgsql \
        php-gd \
        php-bcmath \
        php-apcu \
        php-tidy \
        php-ldap \
        php-memcached \
        git \
        unzip \
        vim \
        postgresql \
        memcached \
        nodejs \
    && dnf clean all -y

# ── Yarn ──────────────────────────────────────────────────────────────────────
RUN npm install -g yarn \
    && yarn --version

# ── Verify PHP 8.4 ────────────────────────────────────────────────────────────
RUN php --version | grep -E "^PHP 8\.4" || \
    { echo "ERROR: Expected PHP 8.4, got: $(php --version | head -1)"; exit 1; }

# ── Composer ──────────────────────────────────────────────────────────────────
RUN curl -sS https://getcomposer.org/installer \
    | php -- --install-dir=/usr/local/bin --filename=composer \
    && composer --version

# ── Symfony CLI ───────────────────────────────────────────────────────────────
RUN curl -1sLf 'https://dl.cloudsmith.io/public/symfony/stable/setup.rpm.sh' \
        | bash \
    && dnf install -y symfony-cli \
    && dnf clean all -y \
    && symfony version

# ── Working directory ─────────────────────────────────────────────────────────
# Running as root inside a rootless container is safe — root inside the
# container simply maps to your unprivileged user account on the host.
WORKDIR /app

# Symfony CLI keeps server state and local TLS certs here
VOLUME /root/.symfony5

EXPOSE 8000
