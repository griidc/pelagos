FROM rockylinux:9

LABEL description="Symfony Development Server — PHP 8.4"

# ── All repos, packages, tools installed and cleaned in a single layer ────────
#
# A single RUN means:
#   - dnf cache never persists into a committed layer
#   - npm cache never persists into a committed layer
#   - repo setup scripts and their deps are cleaned up in the same layer
#   - the final committed layer contains only the installed files
#
RUN \
    # ── DNF baseline config — suppress weak deps and docs globally ────────────
    echo "install_weak_deps=False" >> /etc/dnf/dnf.conf \
    && echo "tsflags=nodocs" >> /etc/dnf/dnf.conf \
    \
    # ── EPEL (needed for memcached etc) ───────────────────────────────────────
    && dnf install -y epel-release \
    \
    # ── Remi repo for PHP 8.4 ─────────────────────────────────────────────────
    && dnf install -y \
        https://rpms.remirepo.net/enterprise/remi-release-9.rpm \
    && dnf module reset php -y \
    && dnf module enable php:remi-8.4 -y \
    \
    # ── NodeSource LTS repo ───────────────────────────────────────────────────
    && curl -fsSL https://rpm.nodesource.com/setup_lts.x | bash - \
    \
    # ── All packages in one transaction ───────────────────────────────────────
    && dnf install -y \
        php-cli \
        php-common \
        php-intl \
        php-mbstring \
        php-xml \
        php-curl \
        php-zip \
        php-sodium \
        php-opcache \
        php-ctype \
        php-pdo \
        php-pgsql \
        php-gd \
        php-bcmath \
        php-apcu \
        php-tidy \
        php-ldap \
        php-memcached \
        unzip \
        ca-certificates \
        vim-minimal \
        postgresql \
        memcached \
        nodejs \
    \
    # ── Yarn via npm ──────────────────────────────────────────────────────────
    && npm install -g yarn \
    \
    # ── Composer ──────────────────────────────────────────────────────────────
    && curl -sS https://getcomposer.org/installer \
        | php -- --install-dir=/usr/local/bin --filename=composer \
    \
    # ── Symfony CLI ───────────────────────────────────────────────────────────
    && curl -1sLf 'https://dl.cloudsmith.io/public/symfony/stable/setup.rpm.sh' \
        | bash - \
    && dnf install -y symfony-cli \
    \
    # ── Aggressive cleanup in the same layer ──────────────────────────────────
    && dnf clean all \
    && npm cache clean --force \
    && rm -rf \
        /var/cache/dnf \
        /var/cache/yum \
        /var/log/dnf* \
        /var/log/yum* \
        /tmp/* \
        /var/tmp/* \
        /root/.npm \
        /usr/share/doc \
        /usr/share/man \
        /usr/share/info \
        /usr/share/locale \
    \
    # ── Verify PHP 8.4 ────────────────────────────────────────────────────────
    && php --version | grep -E "^PHP 8\.4" || \
        { echo "ERROR: Expected PHP 8.4, got: $(php --version | head -1)"; exit 1; } \
    \
    # ── Verify everything installed correctly ─────────────────────────────────
    && composer --version \
    && symfony version \
    && yarn --version

# ── Working directory ─────────────────────────────────────────────────────────
WORKDIR /app

VOLUME /root/.symfony5

EXPOSE 8000
